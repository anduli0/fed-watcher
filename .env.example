# Anthropic API key — NOT required when running via Claude Code CLI (claude -p)
# Only needed if you switch back to direct Anthropic SDK usage
# ANTHROPIC_API_KEY=sk-ant-...

# FRED
FRED_API_KEY=your_fred_api_key_here

# Auth
JWT_SECRET=generate-a-long-random-string-here
ADMIN_PASSWORD_HASH=bcrypt-hash-of-your-password

# Hardware lock — run: python -c "import uuid; print(hex(uuid.getnode()))"
OWNER_MAC=aa:bb:cc:dd:ee:ff

# IP whitelist (comma-separated)
ALLOWED_IPS=127.0.0.1,192.168.0.1

# Model
MODEL_ID=claude-sonnet-4-6
